{
  "name": "freeway-escape",
  "version": "1.0.0",
  "description": "An outrun-style racing game",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "start": "serve .",
    "test:driving": "node ../scripts/driving-physics-smoke.mjs",
    "test:traffic": "node ../scripts/traffic-flow-smoke.mjs",
