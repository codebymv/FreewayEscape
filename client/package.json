    "test:hitbox": "node ../scripts/hitbox-smoke.mjs",
    "test:progression": "node ../scripts/progression-smoke.mjs",
    "test": "npm run test:driving && npm run test:traffic && npm run test:track-shape && npm run test:hitbox && npm run test:progression"
